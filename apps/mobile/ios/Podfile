platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def guardian_read_key_from_file(path, names)
  return nil unless File.exist?(path)

  File.foreach(path) do |line|
    cleaned = line.strip
    next if cleaned.empty? || cleaned.start_with?('#')

    names.each do |name|
      prefix = "#{name}="
      next unless cleaned.start_with?(prefix)

      return cleaned[prefix.length..].to_s.strip.gsub(/\A['"]|['"]\z/, '')
    end
  end

  nil
end

def guardian_maps_api_key
  root = File.expand_path('../../..', __dir__)
  candidates = [
    File.join(__dir__, 'Flutter', 'Maps.xcconfig'),
    File.join(root, 'apps', 'mobile', '.env'),
    File.join(root, 'apps', 'mobile', 'android', 'local.properties'),
    File.join(root, 'apps', 'backend', '.env'),
  ]
  names = ['MAPS_API_KEY_IOS', 'MAPS_API_KEY']

  candidates.each do |path|
    key = guardian_read_key_from_file(path, names)
    return key unless key.nil? || key.empty?
  end

  ENV['MAPS_API_KEY_IOS'] || ENV['MAPS_API_KEY'] || ''
end

target 'Runner' do
  use_frameworks! :linkage => :static
  
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  maps_api_key = guardian_maps_api_key

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Allow non-modular includes in framework modules to support hybrid SPM/CocoaPods setups
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      
      # Force deployment target to be at least 15.0 for all Pods to avoid compiler/deployment target errors
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        current_target = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f
        if current_target < 15.0
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        end
      end
    end
  end
  
  installer.aggregate_targets.each do |target|
    target.user_project.targets.each do |user_target|
      user_target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['MAPS_API_KEY'] = maps_api_key unless maps_api_key.empty?
      end
    end
    target.user_project.save
  end
end
