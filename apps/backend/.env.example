# Database Connection
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/guardian

# Security Keys (JWT)
JWT_SECRET=generate-a-secure-long-string-for-access-tokens
JWT_REFRESH_SECRET=generate-another-secure-long-string-for-refresh-tokens

# Configurations
OTP_TTL_SECONDS=300
RATE_LIMIT_WINDOW_SECONDS=60
PORT=8000
RUST_LOG=info

# ── Infobip 2FA SMS Gateway (Required for Production OTP) ──────────────────────
# Without these, the backend will log the OTP to the console instead of sending SMS
INFOBIP_API_KEY=your_infobip_api_key_here
INFOBIP_BASE_URL=554ppj.api.infobip.com
INFOBIP_APPLICATION_ID=your_application_id_here
INFOBIP_MESSAGE_ID=your_message_id_here
INFOBIP_SENDER=Guardian
# ───────────────────────────────────────────────────────────────────────────────
