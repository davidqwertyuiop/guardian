# Database Connection (from infrastructure/docker-compose.yml)
DATABASE_URL=postgres://guardian_user:secure_db_pass@127.0.0.1:5432/guardian_db

# Security Keys (JWT)
JWT_SECRET=dev-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Configurations
OTP_TTL_SECONDS=300
RATE_LIMIT_WINDOW_SECONDS=60
PORT=8080
RUST_LOG=guardian_backend=debug,tower_http=debug,axum=debug
